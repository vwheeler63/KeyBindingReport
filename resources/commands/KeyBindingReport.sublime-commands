			"packages": ["Default"],
			"key_groups": [5],
			"format": 1,
			"flags": 255,
		},
	},

	{
		"caption": "KeyBindingReport: For Specific Key Combinations for All Installed Packages",
		"command": "key_binding_report",
		"args": {
			"key_groups": [-2],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Key Sequences for All Installed Packages",
		"command": "key_binding_report",
		"args": {
			"key_groups": [-1],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Letter Keys for All Installed Packages",
		"command": "key_binding_report",
		"args": {
			"key_groups": [0],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Number Keys for All Installed Packages",
