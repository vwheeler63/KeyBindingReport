[
	// Items listed here become available in the Command Palette.
	{
		"caption": "KeyBindingReport: Open Readme",
		"command": "open_file",
		"args": {
			"file": "${packages}/KeyBindingReport/README.md"
		}
	},
	{
		"caption": "Preferences: KeyBindingReport Settings",
		"command": "edit_settings",
		"args": {
			"base_file": "${packages}/KeyBindingReport/resources/settings/KeyBindingReport.sublime-settings",
			"default": "{\n\t$0\n}\n"
		}
	},
	{
		"caption": "Preferences: KeyBindingReport Key Bindings",
		"command": "edit_settings",
		"args": {
			"base_file": "${packages}/KeyBindingReport/resources/keymaps/Default ($platform).sublime-keymap",
			"default": "[\n\t$0\n]\n"
		}
	},

	{
		"caption": "KeyBindingReport: For Specific Key Combinations in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [-2],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Key Sequences in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [-1],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Letter Keys in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [0],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Number Keys in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [1],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Symbol Keys in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [2],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Named Keys in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [3],
			"format": 1,
			"flags": 255,
		},
	},
	{
		"caption": "KeyBindingReport: Function Keys in Default Package",
		"command": "key_binding_report",
		"args": {
			"packages": ["Default"],
			"key_groups": [4],
			"format": 1,
			"flags": 255,
